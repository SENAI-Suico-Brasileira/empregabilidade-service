{
  "name": "empregabilidade-service",
  "version": "1.0.0",
  "description": "API do Portal de Vagas de Emprego",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev":               "NODE_ENV=development nodemon server.js",
    "build":             "prisma generate",
    "start":             "NODE_ENV=production node server.js",
    "db:push":           "prisma db push",
    "db:push:prod":      "prisma db push --skip-generate",
    "db:migrate":        "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio":         "prisma studio",
    "db:seed":           "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
