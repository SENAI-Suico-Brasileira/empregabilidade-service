# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Portal de Empregabilidade SENAI
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# NUNCA versione o arquivo .env (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
#
# DEV  → Aiven (nuvem, exige sslaccept=accept_invalid_certs)
# PROD → MariaDB local no servidor Debian (sem SSL, conexão local)
#
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/BANCO
#
# Desenvolvimento (Aiven):
# DATABASE_URL="mysql://avnadmin:SENHA@HOST.aivencloud.com:PORTA/defaultdb?sslaccept=accept_invalid_certs"
#
# Produção (MariaDB local):
DATABASE_URL="mysql://empregabilidade:SENHA_SEGURA_AQUI@localhost:3306/empregabilidade_db"

# ── Autenticação ──────────────────────────────────────────────────────────────
# JWT_SECRET: use uma string longa e aleatória em produção.
# Gerar: openssl rand -base64 48
JWT_SECRET="troque-esta-chave-use-algo-longo-e-aleatorio"

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta interna do Node.js — o NGINX faz proxy, não expor externamente.
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# DEV  → URL do Vite local
# PROD → domínio ou IP público do servidor (sem barra final)
#
# Desenvolvimento:
# CORS_ORIGIN=http://localhost:5173
#
# Produção:
CORS_ORIGIN=https://seu-dominio.com
