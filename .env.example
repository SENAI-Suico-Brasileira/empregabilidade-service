# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Portal de Empregabilidade SENAI
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# NUNCA versione o arquivo .env (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Aiven MySQL — exige SSL (ssl-mode=REQUIRED)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/BANCO?ssl-mode=REQUIRED
DATABASE_URL="mysql://avnadmin:SUA_SENHA@mysql-XXXX.h.aivencloud.com:15735/defaultdb?ssl-mode=REQUIRED"

# ── Autenticação ──────────────────────────────────────────────────────────────
# Use uma string longa e aleatória. Gerar: openssl rand -base64 48
JWT_SECRET="troque-esta-chave-use-algo-longo-e-aleatorio"

# ── Servidor ──────────────────────────────────────────────────────────────────
# O Render injeta PORT automaticamente — não altere em produção.
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Separe múltiplas origens por vírgula (sem espaço após a vírgula).
# Dev:  http://localhost:5173
# Prod: https://empregabilidade-web.vercel.app
CORS_ORIGIN=http://localhost:5173
