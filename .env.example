# Banco de dados (MySQL — Aiven ou outro provider)
DATABASE_URL="mysql://usuario:senha@host:porta/banco?sslaccept=accept_invalid_certs"

# Segredo para assinar os tokens JWT — use uma string longa e aleatória em produção
JWT_SECRET="troque-esta-chave-use-algo-longo-e-aleatorio"

# Porta do servidor (padrão: 3001)
PORT=3001

# Origem permitida pelo CORS — URL do frontend
CORS_ORIGIN=http://localhost:5173
