# ─────────────────────────────────────────────
# DEV — copie para .env e ajuste os valores
# ─────────────────────────────────────────────

# Banco de dados
# DEV  → Aiven (remoto, com SSL)
# PROD → MySQL local no EC2 (sem SSL, sem sair do servidor)
DATABASE_URL="mysql://usuario:senha@localhost:3306/empregabilidade"

# Segredo para assinar tokens JWT — use string longa e aleatória em produção
JWT_SECRET="troque-esta-chave-use-algo-longo-e-aleatorio"

# Porta interna do Node.js — o Nginx faz proxy, não expor externamente
PORT=3001

# CORS
# DEV  → URL do Vite local
# PROD → origem pública (domínio ou IP do EC2)
CORS_ORIGIN=http://localhost:5173
