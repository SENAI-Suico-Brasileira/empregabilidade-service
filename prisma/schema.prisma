generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Usuários do sistema ───────────────────────────────────────────────────
// ADMIN   → acesso ao painel /adm  (analistas do SENAI)
// COMPANY → acesso ao painel /empresas (RH da empresa parceira)
// Alunos acessam o /mural sem autenticação

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(COMPANY)
  company   Company?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── Empresa parceira ─────────────────────────────────────────────────────
model Company {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  cnpj        String?  @unique
  description String?  @db.Text
  contact     String?

  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─── Categorias de vagas ──────────────────────────────────────────────────
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ─── Vagas de emprego ─────────────────────────────────────────────────────
model Job {
  id         Int      @id @default(autoincrement())
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  companyConfidential Boolean @default(false)

  title                  String
  workLocation           String?
  workSchedule           String?
  responsibilities       String?  @db.Text
  requiredQualifications String?  @db.Text
  desiredQualifications  String?  @db.Text
  benefits               String?  @db.Text

  // Tipo de contrato — usado nos indicadores do admin e visível no mural
  contractType ContractType @default(OTHER)

  salaryType SalaryType @default(NEGOTIABLE)
  salaryMin  String?
  salaryMax  String?

  applicationDeadline DateTime?
  applicationLink     String?

  // Fluxo de aprovação:
  // Empresa cria (PENDING) → Admin aprova (ACTIVE) ou reprova (REJECTED)
  // Empresa pode mover: ACTIVE → IN_PROGRESS, INACTIVE ou COMPLETED
  // COMPLETED é estado terminal — não pode ser revertido
  status          JobStatus @default(PENDING)
  rejectionReason String?   // Preenchido pelo admin ao reprovar

  // Preenchido pela empresa ao marcar como COMPLETED (obrigatório)
  filledBy FilledBy?

  // Preenchido pela empresa ao marcar como INACTIVE (obrigatório)
  pauseReason String?

  lgpdConsent     Boolean @default(false)
  senaiDisclaimer Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jobs")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN   // Analista SENAI
  COMPANY // RH da empresa parceira
}

enum JobStatus {
  PENDING     // Aguardando aprovação do admin
  ACTIVE      // Aprovada — visível no /mural
  IN_PROGRESS // Em andamento — seleção em curso (empresa define)
  COMPLETED   // Vaga preenchida — estado terminal (empresa define)
  INACTIVE    // Pausada pela empresa (requer pauseReason)
  REJECTED    // Reprovada pelo admin
}

enum ContractType {
  CLT        // Carteira assinada
  APPRENTICE // Jovem Aprendiz
  INTERNSHIP // Estágio
  PJ         // Pessoa Jurídica
  OTHER      // Outro / Não informado
}

enum FilledBy {
  SENAI_STUDENT // Aluno ou egresso do SENAI
  OTHER         // Outro candidato
}

enum SalaryType {
  FIXED      // Valor fixo: exibe salaryMin
  RANGE      // Faixa: exibe "salaryMin a salaryMax"
  NEGOTIABLE // À combinar
}
